{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "modules-left": ["custom/user", "niri/workspaces"],
    "modules-center": ["wlr/taskbar", "niri/window"],
    "modules-right": ["mpd", "custom/weather", "idle_inhibitor", "custom/updates", "pulseaudio", "network", "disk", "temperature", "cpu", "memory", "niri/language", "custom/clockify", "clock", "tray"],

    "niri/workspaces": {
        "format": "{index}",
        "all-outputs": true
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },

    "niri/window": {
        "format": "{title}",
        "max-length": 50,
        "separate-outputs": true
    },

    "niri/language": {
        "format": "{short}"
    },

    "mpd": {
        "format": "{stateIcon} {artist} - {title}",
        "format-disconnected": "Disconnected ",
        "format-stopped": "Stopped ",
        "state-icons": {
            "paused": "",
            "playing": ""
        }
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },

    "tray": {
        "spacing": 10
    },

    "clock": {
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },

    "cpu": {
        "format": "{usage}% ",
        "tooltip": false
    },

    "memory": {
        "format": "{}% "
    },

    "network": {
        "format-wifi": "{essid} ",
        "format-ethernet": "Connected ",
        "format-disconnected": "Disconnected ⚠",
        "tooltip-format": "{ifname} via {gwaddr}"
    },

    "custom/user": {
        "format": " {}",
        "exec": "whoami",
        "interval": "once"
    },

    "custom/weather": {
        "format": "{}",
        "exec": "curl -s 'wttr.in/?format=%c+%t'",
        "interval": 1800,
        "tooltip": false
    },

    "custom/updates": {
        "format": " {}",
        "exec": "apt list --upgradable 2>/dev/null | grep -c upgradable || echo 0",
        "interval": 3600,
        "tooltip-format": "Available updates"
    },

    "disk": {
        "format": " {percentage_used}%",
        "path": "/",
        "tooltip-format": "{used} / {total} ({percentage_used}%)"
    },

    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": " {temperatureC}°C",
        "critical-threshold": 80,
        "format-critical": " {temperatureC}°C"
    },

    "custom/clockify": {
        "format": "{}",
        "return-type": "json",
        "exec": "~/.config/waybar/clockify.sh",
        "interval": 60,
        "tooltip": true,
        "on-click": "gtk-launch clockify"
    },

    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    }
}
