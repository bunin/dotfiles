{
    "layer": "top",
    "position": "left",
    "width": 36,
    "spacing": 4,
    "modules-left": [
        "custom/user",
        "niri/workspaces",
        "wlr/taskbar"
    ],
    "modules-center": [],
    "modules-right": [
        "mpd",
        "idle_inhibitor",
        "custom/updates",
        "pulseaudio",
        "network",
        "disk",
        "temperature",
        "cpu",
        "memory",
        "niri/language",
        "clock",
        "tray",
        "custom/logout",
        "custom/restart",
        "custom/poweroff"
    ],
    "niri/workspaces": {
        "format": "{index}",
        "all-outputs": true
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "niri/language": {
        "format": "{short}"
    },
    "mpd": {
        "format": "{stateIcon}",
        "format-disconnected": "",
        "format-stopped": "",
        "state-icons": {
            "paused": "",
            "playing": ""
        },
        "tooltip-format": "{artist} - {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        }
    },
    "tray": {
        "spacing": 4,
        "icon-size": 16
    },
    "clock": {
        "tooltip-format": "<big>{:%A, %B %d, %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d\n%m}",
        "format": "{:%H\n%M}"
    },
    "cpu": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}%"
    },
    "memory": {
        "format": "",
        "tooltip-format": "RAM: {percentage}%"
    },
    "network": {
        "format-wifi": "",
        "format-ethernet": "",
        "format-disconnected": "⚠",
        "tooltip-format": "{ifname} via {gwaddr}\n{essid} {signalStrength}%"
    },
    "custom/user": {
        "format": "",
        "exec": "whoami",
        "interval": "once",
        "tooltip": true,
        "tooltip-format": "{}"
    },
    "custom/updates": {
        "format": "",
        "exec": "apt list --upgradable 2>/dev/null | grep -c upgradable || echo 0",
        "interval": 3600,
        "tooltip-format": "{} updates available",
        "tooltip": true
    },
    "disk": {
        "format": "",
        "path": "/",
        "tooltip-format": "Disk: {used} / {total} ({percentage_used}%)"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "",
        "critical-threshold": 80,
        "format-critical": "",
        "tooltip-format": "Temp: {temperatureC}°C"
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": [
                "",
                "",
                ""
            ]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "Volume: {volume}%\n{desc}"
    },
    "custom/logout": {
        "format": "󰍃",
        "tooltip": true,
        "tooltip-format": "Log out",
        "on-click": "niri msg action quit"
    },
    "custom/restart": {
        "format": "",
        "tooltip": true,
        "tooltip-format": "Restart",
        "on-click": "systemctl reboot"
    },
    "custom/poweroff": {
        "format": "⏻",
        "tooltip": true,
        "tooltip-format": "Power off",
        "on-click": "systemctl poweroff"
    },
    "start_hidden": true,
    "exclusive": false
}
