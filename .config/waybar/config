{
    "layer": "top",
    "position": "left",
    "width": 36,
    "spacing": 4,
    "modules-left": [
        "custom/user",
        "niri/workspaces",
        "wlr/taskbar"
    ],
    "modules-center": [],
    "modules-right": [
        "group/media",
        "group/system",
        "group/clockbox",
        "tray",
        "group/power"
    ],
    "group/power": {
        "orientation": "vertical",
        "modules": [
            "idle_inhibitor",
            "custom/logout",
            "custom/restart",
            "custom/poweroff"
        ]
    },
    "group/media": {
        "orientation": "vertical",
        "modules": [
            "mpris",
            "pulseaudio"
        ]
    },
    "group/system": {
        "orientation": "vertical",
        "modules": [
            "custom/updates",
            "network",
            "disk",
            "temperature",
            "cpu",
            "memory"
        ]
    },
    "group/clockbox": {
        "orientation": "vertical",
        "modules": [
            "niri/language",
            "clock"
        ]
    },

    "niri/workspaces": {
        "format": "{index}",
        "all-outputs": true
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "niri/language": {
        "format": "{short}",
        "on-click": "niri msg action switch-layout next"
    },
    "mpris": {
        "format": "{status_icon}",
        "status-icons": {
            "paused": "´üî",
            "playing": "´üő"
        },
        "tooltip-format": "{artist} - {title}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        "spacing": 4,
        "icon-size": 16
    },
    "clock": {
        "tooltip-format": "<big>{:%A, %B %d, %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d\n%m}",
        "format": "{:%H\n%M}"
    },
    "cpu": {
        "format": "´őŤ",
        "tooltip": true,
        "tooltip-format": "CPU: {usage}%"
    },
    "memory": {
        "format": "´âë",
        "tooltip-format": "RAM: {percentage}%"
    },
    "network": {
        "format-wifi": "´çź",
        "format-ethernet": "´âĘ",
        "format-disconnected": "ÔÜá",
        "tooltip-format": "{ifname} via {gwaddr}\n{essid} {signalStrength}%"
    },
    "custom/user": {
        "format": "´Çç",
        "exec": "whoami",
        "interval": "once",
        "tooltip": true,
        "tooltip-format": "{}"
    },
    "custom/updates": {
        "format": "´ÇÖ",
        "exec": "apt list --upgradable 2>/dev/null | grep -c upgradable || echo 0",
        "interval": 3600,
        "tooltip-format": "{} updates available",
        "tooltip": true
    },
    "disk": {
        "format": "´éá",
        "path": "/",
        "tooltip-format": "Disk: {used} / {total} ({percentage_used}%)"
    },
    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "´őë",
        "critical-threshold": 80,
        "format-critical": "´őë",
        "tooltip-format": "Temp: {temperatureC}┬░C"
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-bluetooth": "{icon}",
        "format-muted": "´ÇŽ",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": [
                "´ÇŽ",
                "´Çž",
                "´ÇĘ"
            ]
        },
        "on-click": "pavucontrol",
        "tooltip-format": "Volume: {volume}%\n{desc}"
    },
    "custom/logout": {
        "format": "ˇ░Źâ",
        "tooltip": true,
        "tooltip-format": "Log out",
        "on-click": "niri msg action quit"
    },
    "custom/restart": {
        "format": "´Ç×",
        "tooltip": true,
        "tooltip-format": "Restart",
        "on-click": "systemctl reboot"
    },
    "custom/poweroff": {
        "format": "ÔĆ╗",
        "tooltip": true,
        "tooltip-format": "Power off",
        "on-click": "systemctl poweroff"
    },
    "start_hidden": true,
    "exclusive": false
}
